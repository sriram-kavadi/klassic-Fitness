<section id="social-proof" class="py-24 px-6 md:px-12 relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal-section">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="w-8 h-[2px] bg-brand"></div>
        <span class="text-brand text-xs font-semibold tracking-[0.3em] uppercase">Results Don't Lie</span>
        <div class="w-8 h-[2px] bg-brand"></div>
      </div>
      <h2 class="font-display text-[clamp(2.5rem,6vw,5rem)] text-white uppercase tracking-wide">Real People.<br/><span class="text-brand">Real Results.</span></h2>
      <p class="text-gray-400 mt-4 text-lg max-w-xl mx-auto">See the transformations happening right now at Klassic Fitness. These aren't stock photos — these are your neighbors.</p>
    </div>

    <!-- Transformation Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      <%
      const transformations = [
        { name: 'Rahul S.', result: 'Lost 18kg', duration: '90 days', type: 'Fat Loss', emoji: '🔥' },
        { name: 'Priya M.', result: 'Built Muscle', duration: '60 days', type: 'Muscle Gain', emoji: '💪' },
        { name: 'Arjun K.', result: 'Lost 12kg', duration: '75 days', type: 'Weight Loss', emoji: '⚡' },
        { name: 'Sneha R.', result: '6-Pack!', duration: '90 days', type: 'Body Recomp', emoji: '🎯' },
      ];
      %>
      <% transformations.forEach((t, i) => { %>
      <div class="transform-card group relative overflow-hidden rounded-2xl bg-darkCard border border-darkBorder hover:border-brand/50 transition-all duration-500 cursor-pointer" data-index="<%= i %>">
        <!-- Fake before/after image area -->
        <div class="aspect-[3/4] relative overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-darkBorder to-[#1a1a1a]">
            <!-- Placeholder with big emoji + data -->
            <div class="text-center p-4">
              <div class="text-6xl mb-3"><%= t.emoji %></div>
              <div class="font-display text-3xl text-brand"><%= t.result %></div>
              <div class="text-white text-sm mt-1">in <%= t.duration %></div>
            </div>
          </div>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-brand/90 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-400 translate-y-4 group-hover:translate-y-0">
            <div class="text-white text-center px-4">
              <div class="font-display text-2xl mb-2"><%= t.name %></div>
              <div class="text-white/90 text-sm mb-1"><%= t.type %> Program</div>
              <div class="text-white font-bold text-lg"><%= t.result %></div>
              <div class="text-white/80 text-sm">in <%= t.duration %></div>
              <div class="mt-4">
                <a href="#lead-form" class="inline-block bg-white text-brand text-sm font-bold px-4 py-2 rounded-full hover:bg-gray-100 transition-colors">Get This Result →</a>
              </div>
            </div>
          </div>
        </div>
        <!-- Card footer -->
        <div class="p-4">
          <div class="font-semibold text-white text-sm"><%= t.name %></div>
          <div class="text-brand text-xs font-bold mt-0.5"><%= t.result %> in <%= t.duration %></div>
        </div>
      </div>
      <% }); %>
    </div>

    <!-- Testimonials slider -->
    <div class="testimonials-row overflow-hidden relative">
      <div class="testimonials-track flex gap-5" id="testimonials-track">
        <%
        const testimonials = [
          { name: 'Vikram S.', role: 'Software Engineer', text: 'I lost 15kg in 3 months. The trainers are incredible and the environment pushes you to your limits. Best investment I\'ve ever made!', stars: 5 },
          { name: 'Ananya P.', role: 'Doctor', text: 'As a doctor I\'m skeptical of fitness claims, but Klassic delivered. Down 10kg, my energy is through the roof. Highly recommend.', stars: 5 },
          { name: 'Rohit T.', role: 'Business Owner', text: 'The 3-day trial sold me instantly. By day 2 I knew I was signing up for a year. The transformation is real.', stars: 5 },
          { name: 'Meera K.', role: 'Teacher', text: 'Never thought I could get in shape at 38. Klassic proved me wrong. Lost 8kg and gained so much confidence!', stars: 5 },
          { name: 'Dev A.', role: 'Startup Founder', text: 'I\'ve been to 5 gyms. Klassic is the only one where I actually see results. The trainers are on another level.', stars: 5 },
        ];
        %>
        <% testimonials.concat(testimonials).forEach((t, i) => { %>
        <div class="testimonial-card flex-shrink-0 w-[320px] bg-darkCard border border-darkBorder rounded-2xl p-6 hover:border-brand/40 transition-colors duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-3">
            <% for(let s=0;s<t.stars;s++) { %><svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% } %>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed mb-4">"<%= t.text %>"</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand/20 border border-brand/40 flex items-center justify-center text-brand font-display text-lg"><%= t.name[0] %></div>
            <div>
              <div class="text-white font-semibold text-sm"><%= t.name %></div>
              <div class="text-gray-500 text-xs"><%= t.role %></div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- CTA nudge -->
    <div class="text-center mt-12 reveal-section">
      <p class="text-gray-400 mb-4">Join <span class="text-white font-semibold">500+ members</span> already transforming their lives</p>
      <a href="#lead-form" class="inline-flex items-center gap-2 bg-brand text-white font-bold px-8 py-4 rounded-lg hover:bg-brandDark transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(255,46,46,0.3)] uppercase tracking-wider text-sm">
        Start Your Transformation →
      </a>
    </div>
  </div>
</section>
