<section id="programs" class="py-24 px-6 md:px-12 bg-gradient-to-b from-dark via-[#0f0f0f] to-dark">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16 reveal-section">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="w-8 h-[2px] bg-brand"></div>
        <span class="text-brand text-xs font-semibold tracking-[0.3em] uppercase">Pick Your Path</span>
        <div class="w-8 h-[2px] bg-brand"></div>
      </div>
      <h2 class="font-display text-[clamp(2.5rem,6vw,5rem)] text-white uppercase tracking-wide">Choose Your <span class="text-brand">Program</span></h2>
      <p class="text-gray-400 mt-4 text-lg max-w-xl mx-auto">Every program is designed with one goal — your transformation. No fluff, only results.</p>
    </div>

    <!-- Program cards -->
    <%
    const programs = [
      {
        icon: '🔥',
        tag: 'Most Popular',
        title: 'Fat Burn Fast',
        subtitle: '4–8 Weeks',
        description: 'Torch fat with high-intensity sessions designed to rev your metabolism and keep it burning 24/7.',
        benefits: ['Cardio + Strength combo', 'Personalized meal guidance', 'Weekly body scans', 'Group motivation sessions'],
        price: '₹1,499/mo',
        originalPrice: '₹4,999/mo',
        cta: 'Lose Fat Now',
        featured: true
      },
      {
        icon: '💪',
        tag: 'Build Mass',
        title: 'Lean Muscle Builder',
        subtitle: '8–12 Weeks',
        description: 'Progressive overload programming to pack on lean muscle and build a physique that commands respect.',
        benefits: ['Compound lifts focus', 'Protein & nutrition plan', 'Strength tracking app', 'Monthly progress pics'],
        price: '₹1,999/mo',
        originalPrice: '₹5,999/mo',
        cta: 'Build Muscle',
        featured: false
      },
      {
        icon: '🧘',
        tag: 'Full Body',
        title: 'Zumba & Cardio',
        subtitle: 'Ongoing',
        description: 'High-energy group sessions that make fitness addictive. Burn calories while having the time of your life.',
        benefits: ['Daily group sessions', 'All fitness levels welcome', 'Fun energetic environment', 'No experience needed'],
        price: '₹999/mo',
        originalPrice: '₹2,999/mo',
        cta: 'Join Group',
        featured: false
      },
      {
        icon: '🎯',
        tag: 'Elite',
        title: 'Personal Training',
        subtitle: '1-on-1 Coaching',
        description: 'Your own dedicated trainer. 100% customized program. Fastest results, guaranteed. The elite path.',
        benefits: ['Dedicated personal trainer', 'Custom workout plan', 'Daily check-ins', '90-day transformation guarantee'],
        price: '₹3,999/mo',
        originalPrice: '₹9,999/mo',
        cta: 'Go Elite',
        featured: false
      },
    ];
    %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      <% programs.forEach((p, i) => { %>
      <div class="program-card group relative flex flex-col bg-darkCard border <%= p.featured ? 'border-brand' : 'border-darkBorder hover:border-brand/40' %> rounded-2xl overflow-hidden transition-all duration-500 hover:translate-y-[-6px] hover:shadow-[0_24px_48px_rgba(255,46,46,0.15)]" data-index="<%= i %>">
        <% if(p.featured) { %>
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-brand via-orange-500 to-brand bg-size-200 animate-gradient-x"></div>
        <% } %>
        
        <div class="p-6 flex-1">
          <!-- Tag + Icon -->
          <div class="flex items-center justify-between mb-5">
            <span class="text-3xl"><%= p.icon %></span>
            <span class="text-xs font-bold px-3 py-1 rounded-full <%= p.featured ? 'bg-brand text-white' : 'bg-darkBorder text-gray-400' %> uppercase tracking-wider"><%= p.tag %></span>
          </div>

          <!-- Title -->
          <h3 class="font-display text-2xl text-white uppercase tracking-wider mb-1"><%= p.title %></h3>
          <div class="text-brand text-sm font-semibold mb-3 uppercase tracking-wider"><%= p.subtitle %></div>
          <p class="text-gray-400 text-sm leading-relaxed mb-5"><%= p.description %></p>

          <!-- Benefits -->
          <ul class="space-y-2 mb-6">
            <% p.benefits.forEach(b => { %>
            <li class="flex items-center gap-2 text-sm text-gray-300">
              <svg class="w-4 h-4 text-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <%= b %>
            </li>
            <% }); %>
          </ul>
        </div>

        <!-- Pricing + CTA -->
        <div class="p-6 pt-0">
          <div class="flex items-baseline gap-2 mb-4">
            <span class="font-display text-2xl text-white"><%= p.price %></span>
            <span class="text-gray-500 text-sm line-through"><%= p.originalPrice %></span>
          </div>
          <a href="#lead-form" class="block w-full text-center font-bold py-3 rounded-lg uppercase tracking-wider text-sm transition-all duration-300 <%= p.featured ? 'bg-brand text-white hover:bg-brandDark hover:shadow-[0_0_20px_rgba(255,46,46,0.4)]' : 'bg-darkBorder text-white hover:bg-brand hover:text-white' %>">
            <%= p.cta %> →
          </a>
        </div>
      </div>
      <% }); %>
    </div>

    <!-- Starting from -->
    <div class="text-center mt-10 reveal-section">
      <p class="text-gray-500 text-sm">Plans starting from <span class="text-white font-semibold">₹999/month</span> · No long-term contracts · Cancel anytime</p>
    </div>
  </div>
</section>
